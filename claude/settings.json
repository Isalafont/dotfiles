{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read(**/note_datapass/**)",
      "Write(**/note_datapass/**)",
      "Edit(**/note_datapass/**)",
      "Bash(mkdir -p /Users/isalafont/code/BetaGouv/note_datapass/**)",
      "Read(/Users/isalafont/.claude/projects/**/memory/**)",
      "Write(/Users/isalafont/.claude/projects/**/memory/**)",
      "Edit(/Users/isalafont/.claude/projects/**/memory/**)"
    ],
    "deny": [
      "Read(**/.ssh/*)",
      "Read(**/*.pem)",
      "Read(**/*_rsa)",
      "Read(**/*_ed25519)",
      "Read(**/*password*)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Read(**/.gnupg/*)",
      "Bash(wget *)",
      "Bash(eval *)",
      "Bash(ruby -e *)",
      "Bash(node -e *)",
      "Bash(bash -c *)",
      "Bash(sh -c *)",
      "Bash(curl * | *)",
      "Read(**/.netrc)",
      "Read(**/.aws/credentials)",
      "Read(**/.pgpass)"
    ],
    "ask": [
      "Bash(git commit*)",
      "Bash(git push*)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/morning_check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/bash-tool-call.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/skill-version-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session_start_linear.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/evening_check.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "accessibility@rgaa-toolkit": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "layered-rails@palkan-skills": true,
    "ralph-loop@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "rgaa-toolkit": {
      "source": {
        "source": "directory",
        "path": "/Users/isalafont/code/Isalafont/dotfiles/claude/marketplaces/rgaa-dev"
      }
    },
    "palkan-skills": {
      "source": {
        "source": "github",
        "repo": "palkan/skills"
      }
    }
  },
  "language": "french",
  "tui": "fullscreen",
  "showThinkingSummaries": true,
  "theme": "auto",
  "verbose": true,
  "skipAutoPermissionPrompt": true
}
